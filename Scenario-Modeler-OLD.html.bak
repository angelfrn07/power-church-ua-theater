      <!-- DSCR + CASH FLOW LAYERED -->
      <div class="grid-card rounded-2xl p-5 sm:p-6 shadow-sm">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-4 gap-2">
