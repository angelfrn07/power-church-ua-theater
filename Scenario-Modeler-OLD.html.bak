<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>Power Church · UA Theater · Scenario Modeler</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Anton&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">

<style>
  :root {
    /* Power Church Amarillo brand */
    --ink: #0d0d0d;
    --moss: #ff6123;        /* POWER ORANGE — primary accent */
    --moss-2: #ff7a47;      /* lighter shade for gradients */
    --gold: #c8932b;        /* secondary warm accent */
    --cream: #fef6ed;       /* warm off-white background */
    --mist: #fde9d4;        /* peach mist surface */
    --line: #f0d4b1;        /* warm line color */
    --deep: #1a1a1a;        /* deep text */
    --good: #15803d;
    --warn: #b45309;
    --bad: #b91c1c;
  }
  html, body {
    background: var(--cream);
    color: var(--ink);
    font-family: "Inter", system-ui, -apple-system, "Helvetica Neue", sans-serif;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  /* Power Church uses Anton for display — tall condensed all-caps */
  .display, .pp {
    font-family: "Anton", "Inter", system-ui, sans-serif;
    font-weight: 400;
    letter-spacing: 0.005em;
    text-transform: uppercase;
    line-height: 0.95;
  }
  .mono { font-family: "JetBrains Mono", ui-monospace, "SF Mono", monospace; font-variant-numeric: tabular-nums; }
  .num { font-variant-numeric: tabular-nums; }

  .topo {
    background-image:
      radial-gradient(1200px circle at 0% 0%, rgba(255,97,35,0.10), transparent 55%),
      radial-gradient(900px circle at 100% 0%, rgba(250,207,159,0.45), transparent 55%);
  }

  .scenario-card {
    transition: transform 0.4s cubic-bezier(0.2,0.8,0.2,1), box-shadow 0.4s ease, border-color 0.4s ease;
  }
  .scenario-card:hover {
    transform: translateY(-3px);
  }

  /* Custom slider */
  input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    height: 4px;
    background: var(--line);
    border-radius: 999px;
    outline: none;
  }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 22px;
    height: 22px;
    background: var(--moss);
    border: 3px solid var(--cream);
    box-shadow: 0 2px 6px rgba(15,58,46,0.35);
    border-radius: 999px;
    cursor: grab;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  input[type="range"]::-webkit-slider-thumb:hover {
    transform: scale(1.1);
    box-shadow: 0 3px 10px rgba(15,58,46,0.5);
  }
  input[type="range"]::-webkit-slider-thumb:active { cursor: grabbing; }
  input[type="range"]::-moz-range-thumb {
    width: 22px;
    height: 22px;
    background: var(--moss);
    border: 3px solid var(--cream);
    border-radius: 999px;
    cursor: grab;
  }

  .pulse-good { animation: flashGood 0.6s ease; }
  .pulse-bad { animation: flashBad 0.6s ease; }
  @keyframes flashGood { 0%{background:rgba(21,128,61,0.18)} 100%{background:transparent} }
  @keyframes flashBad { 0%{background:rgba(185,28,28,0.18)} 100%{background:transparent} }

  .preset-btn { position: relative; }
  .preset-btn.preset-active {
    border-color: var(--moss) !important;
    background: linear-gradient(135deg, #ecfdf5 0%, #fef3c7 100%) !important;
    box-shadow: 0 4px 14px rgba(15,58,46,0.18);
    transform: translateY(-1px);
  }
  .preset-btn.preset-active::after {
    content: '✓';
    position: absolute;
    top: 6px;
    right: 8px;
    font-size: 10px;
    color: var(--moss);
    font-weight: 900;
  }

  .badge { letter-spacing: 0.04em; }

  /* DSCR meter */
  .meter-track {
    height: 14px;
    background: linear-gradient(to right, #fee2e2 0%, #fef3c7 50%, #dcfce7 100%);
    border-radius: 999px;
    overflow: hidden;
    position: relative;
  }
  .meter-marker {
    position: absolute;
    top: -5px;
    width: 4px;
    height: 24px;
    background: var(--ink);
    border-radius: 2px;
    transition: left 0.5s cubic-bezier(0.2,0.8,0.2,1);
    transform: translateX(-50%);
  }

  .verdict-pill {
    transition: all 0.4s cubic-bezier(0.2,0.8,0.2,1);
  }

  /* Tier toggle */
  .tier-btn {
    transition: all 0.2s ease;
  }
  .tier-btn[data-active="true"] {
    background: var(--moss);
    color: var(--cream);
    box-shadow: 0 4px 14px rgba(15,58,46,0.3);
  }

  details > summary { list-style: none; cursor: pointer; }
  details > summary::-webkit-details-marker { display: none; }
  .chev { transition: transform 0.25s ease; }
  details[open] .chev { transform: rotate(90deg); }

  .grid-card {
    border: 1px solid var(--line);
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(8px);
  }

  /* (Anton-based .pp class is already defined above) */

  /* Sensitivity heatmap */
  .heat-cell {
    transition: background-color 0.4s ease, color 0.4s ease, transform 0.2s ease;
  }
  .heat-cell:hover { transform: scale(1.05); }

  /* Subtle accent line */
  .accent-line {
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    height: 1px;
  }

  @media print {
    .no-print { display: none !important; }
  }
</style>
</head>
<body class="topo min-h-screen">

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-10">

  <!-- HEADER -->
  <header class="mb-8">
    <div class="flex items-center gap-3 mb-3">
      <img src="power-church-logo.png" alt="Power Church" style="height: 56px; width: auto; display: block;" />
      <div>
        <div class="text-xs uppercase tracking-[0.22em] text-[color:var(--moss)] font-bold">Power Church · Building Committee</div>
        <div class="text-xs text-stone-500">Live as of <span id="now"></span></div>
      </div>
    </div>
    <h1 class="pp text-5xl sm:text-6xl lg:text-7xl text-[color:var(--ink)]">
      UA Theater<br/>
      <span class="text-[color:var(--moss)]">Scenario Modeler</span>
    </h1>
    <p class="mt-4 text-stone-700 text-base sm:text-lg max-w-3xl">
      Drag the sliders. Toggle the income tier. The three scenarios update live.
      Use this in the committee meeting, on the bank call, or to stress-test before saying yes.
    </p>
    <div class="accent-line mt-5"></div>
  </header>

  <!-- KEY VERDICT BANNER -->
  <div id="verdictBanner" class="verdict-pill rounded-2xl px-5 sm:px-7 py-5 mb-4 text-white"
       style="background: linear-gradient(135deg, var(--moss) 0%, var(--moss-2) 100%);">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <div class="text-xs uppercase tracking-[0.2em] text-amber-100 mb-1">Recommendation at these numbers</div>
        <div id="verdictText" class="pp text-2xl sm:text-3xl"></div>
      </div>
      <div class="text-right">
        <div class="text-xs uppercase tracking-[0.18em] text-amber-100 mb-1">Best Coverage</div>
        <div id="bestDscr" class="pp text-3xl sm:text-4xl mono">--</div>
        <div class="text-[10px] uppercase tracking-[0.16em] text-amber-100 mt-0.5">income ÷ payment</div>
      </div>
    </div>
  </div>

  <!-- COMMITTEE STORY PANEL — plain English narrative -->
  <div class="rounded-2xl px-5 sm:px-7 py-5 mb-8 bg-[color:var(--cream)] border border-[color:var(--line)]">
    <div class="flex items-center gap-2 mb-3">
      <div class="text-xs uppercase tracking-[0.2em] text-[color:var(--moss)] font-bold">For the committee · plain English</div>
      <button id="storyToggle" class="ml-auto text-xs uppercase tracking-wider text-stone-500 hover:text-[color:var(--moss)] transition">Hide</button>
    </div>
    <div id="storyBody" class="space-y-3 text-sm sm:text-base text-stone-800 leading-relaxed">
      <p id="storyDeal"></p>
      <p id="storyLoc" class="bg-white -mx-3 px-3 py-2 rounded-lg border-l-4 border-[color:var(--moss)]"></p>
      <p id="storyMoney"></p>
      <p id="storyRisk"></p>
      <p id="storyAsk" class="font-semibold"></p>
    </div>
    <div class="mt-4 pt-3 border-t border-dashed border-[color:var(--line)] grid grid-cols-2 sm:grid-cols-4 gap-3 text-center">
      <div><div class="text-[10px] uppercase tracking-wider text-stone-500">Building cost</div><div id="kpiBuilding" class="pp text-xl text-[color:var(--moss)]">--</div></div>
      <div><div class="text-[10px] uppercase tracking-wider text-stone-500">Cash at closing</div><div id="kpiCash" class="pp text-xl text-[color:var(--moss)]">--</div></div>
      <div><div class="text-[10px] uppercase tracking-wider text-stone-500">Mortgage when done</div><div id="kpiMortgage" class="pp text-xl text-[color:var(--moss)]">--</div></div>
      <div><div class="text-[10px] uppercase tracking-wider text-stone-500">Income covers it?</div><div id="kpiCovers" class="pp text-xl text-[color:var(--moss)]">--</div></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">

    <!-- LEFT: INPUTS -->
    <aside class="lg:col-span-4 lg:sticky lg:top-4 self-start no-print">
      <div class="grid-card rounded-2xl p-5 sm:p-6 shadow-sm">
        <div class="flex items-center justify-between mb-4">
          <h2 class="pp text-2xl">Inputs</h2>
          <button id="resetBtn" class="text-xs uppercase tracking-wider text-stone-500 hover:text-[color:var(--moss)] transition">Reset</button>
        </div>

        <!-- Tier selector -->
        <div class="mb-5">
          <label class="block text-xs uppercase tracking-wider text-stone-500 mb-2">How much side income do we count on?</label>
          <div class="grid grid-cols-4 gap-1 bg-[color:var(--mist)] p-1 rounded-xl text-[11px] sm:text-xs font-semibold">
            <button class="tier-btn rounded-lg py-2 text-stone-600" data-tier="layer1" title="Existing tithes only — no side income from the new building">Tithes<span class="hidden sm:inline"> only</span></button>
            <button class="tier-btn rounded-lg py-2 text-stone-600" data-tier="layer2" data-active="true" title="A few extras: rentals, weddings, light events">Light<span class="hidden sm:inline"> extras</span></button>
            <button class="tier-btn rounded-lg py-2 text-stone-600" data-tier="layer3" title="9 revenue streams: gym, daycare, café, events, conference rentals">Strong<span class="hidden sm:inline"> mix</span></button>
            <button class="tier-btn rounded-lg py-2 text-stone-600" data-tier="layer4" title="All 9 streams optimized — full conference center activation">All-out</button>
          </div>
          <div class="mt-2 flex justify-between text-[11px] text-stone-500">
            <span>Side income added</span>
            <span id="tierMonthlySupp" class="mono font-semibold text-[color:var(--moss)]">+$25,000/mo net</span>
          </div>
        </div>

        <!-- Quick-set presets -->
        <div class="mb-5">
          <label class="block text-xs uppercase tracking-wider text-stone-500 mb-2">Quick Scenarios</label>
          <div class="grid grid-cols-2 gap-2">
            <button class="preset-btn group flex flex-col items-start text-left p-2.5 rounded-xl border border-stone-200 hover:border-[color:var(--moss)] hover:bg-emerald-50 transition" data-preset="listing">
              <span class="text-[10px] uppercase tracking-wider text-stone-500 group-hover:text-[color:var(--moss)]">As Listed</span>
              <span class="text-sm font-bold text-[color:var(--ink)]">$5.5M · No Discount</span>
              <span class="text-[10px] text-stone-400 mt-0.5">Worst case · what if seller won't budge</span>
            </button>
            <button class="preset-btn group flex flex-col items-start text-left p-2.5 rounded-xl border-2 border-[color:var(--moss)] bg-emerald-50 transition" data-preset="negotiatedA">
              <span class="text-[10px] uppercase tracking-wider text-[color:var(--moss)] font-bold">Scenario A · Lead</span>
              <span class="text-sm font-bold text-[color:var(--ink)]">$4M + Seller Carry</span>
              <span class="text-[10px] text-stone-500 mt-0.5">$2M carry · $2M bank construction</span>
            </button>
            <button class="preset-btn group flex flex-col items-start text-left p-2.5 rounded-xl border border-stone-200 hover:border-[color:var(--gold)] hover:bg-amber-50 transition" data-preset="masterLeaseC">
              <span class="text-[10px] uppercase tracking-wider text-stone-500 group-hover:text-[color:var(--gold)]">Scenario C · Fallback</span>
              <span class="text-sm font-bold text-[color:var(--ink)]">Master Lease + $3.8M</span>
              <span class="text-[10px] text-stone-400 mt-0.5">$3/sqft lease · option to buy</span>
            </button>
            <button class="preset-btn group flex flex-col items-start text-left p-2.5 rounded-xl border border-stone-200 hover:border-rose-400 hover:bg-rose-50 transition" data-preset="stress">
              <span class="text-[10px] uppercase tracking-wider text-stone-500 group-hover:text-rose-600">Stress Test</span>
              <span class="text-sm font-bold text-[color:var(--ink)]">9% Rates · L1 Only</span>
              <span class="text-[10px] text-stone-400 mt-0.5">Tithes-only at high rates</span>
            </button>
            <button class="preset-btn group flex flex-col items-start text-left p-2.5 rounded-xl border border-stone-200 hover:border-emerald-500 hover:bg-emerald-50 transition" data-preset="bull">
              <span class="text-[10px] uppercase tracking-wider text-stone-500 group-hover:text-emerald-700">Bull Case</span>
              <span class="text-sm font-bold text-[color:var(--ink)]">L3 Moderate · 7% Rates</span>
              <span class="text-[10px] text-stone-400 mt-0.5">Year 2-3 stabilized operations</span>
            </button>
          </div>
        </div>

        <div class="accent-line my-4"></div>

        <!-- Sliders -->
        <div class="space-y-5">
          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Negotiated Purchase</label>
              <span id="lblPurchase" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="purchase" min="3000000" max="5500000" step="50000" value="4000000" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>$3.0M</span><span>list $5.5M</span></div>
          </div>

          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Renovation Budget</label>
              <span id="lblReno" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="reno" min="1500000" max="3500000" step="50000" value="2000000" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>$1.5M</span><span>$3.5M</span></div>
          </div>

          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Construction Months</label>
              <span id="lblMonths" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="months" min="9" max="18" step="1" value="12" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>9 mo</span><span>18 mo</span></div>
          </div>

          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Bank Construction Rate (IO)</label>
              <span id="lblBankIO" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="bankIO" min="6.0" max="10.0" step="0.1" value="8.0" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>6.0%</span><span>10.0%</span></div>
          </div>

          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Bank Permanent Rate · 25-yr</label>
              <span id="lblBankPerm" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="bankPerm" min="5.5" max="9.5" step="0.1" value="7.5" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>5.5%</span><span>9.5%</span></div>
          </div>

          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Seller Carry Rate (IO)</label>
              <span id="lblSeller" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="seller" min="3.0" max="9.0" step="0.1" value="6.0" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>3.0%</span><span>9.0%</span></div>
          </div>

          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Master Lease ($/sqft / yr)</label>
              <span id="lblLease" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="lease" min="1.0" max="6.0" step="0.25" value="3.0" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>$1</span><span>$6</span></div>
          </div>

          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Existing Church Net (mo)</label>
              <span id="lblNet" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="net" min="15000" max="60000" step="1000" value="25000" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>$15K</span><span>$60K</span></div>
          </div>

          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Supplementary Net Margin</label>
              <span id="lblMargin" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="margin" min="20" max="80" step="5" value="50" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>20%</span><span>80%</span></div>
          </div>

          <div>
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-medium">Master Lease Buyout Price</label>
              <span id="lblBuyout" class="mono text-sm font-semibold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="buyout" min="3000000" max="5000000" step="50000" value="3800000" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-400 mt-0.5"><span>$3.0M</span><span>$5.0M</span></div>
          </div>

          <div class="pt-3 border-t border-[color:var(--line)]">
            <div class="flex justify-between items-baseline mb-1">
              <label class="text-sm font-bold text-[color:var(--moss)]">Building ARV (post-construction)</label>
              <span id="lblArv" class="mono text-sm font-bold text-[color:var(--moss)]"></span>
            </div>
            <input type="range" id="arv" min="5000000" max="12000000" step="100000" value="9100000" class="w-full">
            <div class="flex justify-between text-[10px] text-stone-500 mt-0.5">
              <span class="text-rose-600 font-semibold">$7.5M Low (25%)</span>
              <span class="text-emerald-700 font-bold">$9.1M Mid (50%)</span>
              <span class="text-emerald-600 font-semibold">$11.0M High (25%)</span>
            </div>
            <div class="text-[10px] text-stone-600 mt-2 leading-snug bg-white p-2 rounded border border-[color:var(--line)]">
              <strong class="text-[color:var(--moss)]">Research-backed range</strong> (see source-4-ARV-Research.md): bank weights income approach 60% / comps 30% / cost 10%. Mid-case $9.1M needs ≥50% commercial leases signed by month 11 + 6 months of $1.2M-pace P&L documented before appraisal walk-through.
            </div>
          </div>

          <!-- EXISTING BUILDING LEVERAGE — LOC against SE 10th Ave -->
          <div class="pt-4 mt-4 border-t-2 border-[color:var(--moss)] bg-[color:var(--mist)] -mx-5 px-5 py-3 rounded-xl">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-2 h-2 rounded-full bg-[color:var(--moss)]"></div>
              <h4 class="pp text-base text-[color:var(--moss)]">Existing Building · Power Source</h4>
            </div>
            <div class="text-[11px] text-stone-600 mb-3 leading-relaxed">
              Pull a line of credit against the current SE 10th Ave building <strong>BEFORE</strong> taking on UA Theater debt. Bank underwrites it while your balance sheet is clean.
            </div>

            <div class="mb-3">
              <div class="flex justify-between items-baseline mb-1">
                <label class="text-xs font-semibold">Existing Building Appraised Value</label>
                <span id="lblExistAppr" class="mono text-xs font-bold text-[color:var(--moss)]"></span>
              </div>
              <input type="range" id="existAppr" min="1500000" max="2500000" step="50000" value="1900000" class="w-full">
              <div class="flex justify-between text-[10px] text-stone-500 mt-0.5">
                <span>$1.5M</span>
                <span class="italic">Deeter's range: $1.8–2.0M</span>
                <span>$2.5M</span>
              </div>
            </div>

            <div class="mb-3">
              <div class="flex justify-between items-baseline mb-1">
                <label class="text-xs font-semibold">Bank LOC % (typical 60–70%)</label>
                <span id="lblLocLtv" class="mono text-xs font-bold text-[color:var(--moss)]"></span>
              </div>
              <input type="range" id="locLtv" min="0.50" max="0.75" step="0.01" value="0.60" class="w-full">
              <div class="flex justify-between text-[10px] text-stone-500 mt-0.5">
                <span>50%</span>
                <span>60%</span>
                <span>75%</span>
              </div>
            </div>

            <div class="mb-3">
              <div class="flex justify-between items-baseline mb-1">
                <label class="text-xs font-semibold">LOC Rate (interest only)</label>
                <span id="lblLocRate" class="mono text-xs font-bold text-[color:var(--moss)]"></span>
              </div>
              <input type="range" id="locRate" min="0.06" max="0.12" step="0.0025" value="0.085" class="w-full">
            </div>

            <div class="mt-3 grid grid-cols-2 gap-2 text-center">
              <div class="bg-white rounded-lg p-2 border border-[color:var(--line)]">
                <div class="text-[9px] uppercase tracking-wider text-stone-500">LOC Available</div>
                <div id="locAvail" class="pp text-lg text-[color:var(--moss)]">--</div>
              </div>
              <div class="bg-white rounded-lg p-2 border border-[color:var(--line)]">
                <div class="text-[9px] uppercase tracking-wider text-stone-500">If fully drawn / mo</div>
                <div id="locMonthly" class="pp text-lg text-stone-700">--</div>
              </div>
            </div>
          </div>
        </div>

        <details class="mt-5 group">
          <summary class="text-xs uppercase tracking-wider text-stone-500 hover:text-[color:var(--moss)] flex items-center gap-2">
            <span class="chev">▸</span> Constants & assumptions
          </summary>
          <div class="mt-3 text-xs text-stone-600 space-y-1">
            <div>Building: <span class="mono">83,422 sqft</span> (Llano listing)</div>
            <div>SE 10th carrying: <span class="mono">$5,000/mo</span></div>
            <div>Vacant shell carrying: <span class="mono">$5,000/mo</span></div>
            <div>Insurance escrow: <span class="mono">$4,000/mo</span></div>
            <div>Property tax: <span class="mono">$0</span> (501c3 exempt post-occupancy)</div>
            <div>Closing costs: <span class="mono">3.0%</span> of refi loan</div>
            <div>Refi LTV target: <span class="mono">75%</span></div>
            <div>Replacement cost reference: <span class="mono">$87/sqft</span> = <span class="mono">$7.26M</span></div>
          </div>
        </details>
      </div>
    </aside>

    <!-- RIGHT: OUTPUTS -->
    <main class="lg:col-span-8 space-y-6">

      <!-- THREE SCENARIO CARDS -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Scenario A — Committee's Current Plan (CONVENTIONAL) -->
        <div class="scenario-card grid-card rounded-2xl p-5 shadow-sm border-l-4 border-[color:var(--moss)]" id="cardA">
          <div class="flex items-start justify-between mb-2">
            <div>
              <div class="text-xs badge uppercase tracking-[0.18em] text-stone-500">Scenario A · Committee's Current Plan</div>
              <h3 class="pp text-xl text-[color:var(--ink)]">Conventional Purchase</h3>
            </div>
            <div id="verdictA" class="text-[10px] badge uppercase tracking-wider px-2 py-1 rounded-full">--</div>
          </div>
          <div class="text-[11px] text-stone-500 mb-3">Per Power Church LOI: $3.8M purchase from Cinergy · 20% down ($760K from LOC) · $3.04M ANB loan @ 7% / 25-yr (full P+I from day 1, no construction loan, no seller carry) · Reno paid from cash flow ($100-500K)</div>

          <div class="space-y-2 text-sm">
            <div class="flex justify-between" title="Down payment + closing costs + initial cash reno (per Board Review's $900K-$1.2M range)"><span class="text-stone-500">Cash needed at closing</span><span id="aY0" class="mono font-semibold">--</span></div>
            <div class="flex justify-between" title="Year 1 = bank P+I + UA ops + LOC IO + SE 10th (still held during transition)"><span class="text-stone-500">Year 1 monthly burn</span><span id="aBurden" class="mono font-semibold">--</span></div>
            <div class="flex justify-between border-t border-stone-200 pt-2" title="Year 1 surplus/(deficit) vs net giving (existing $25K + Layer 2 supp). Negative = LOC reserve fills the gap."><span class="font-medium">Year 1 surplus / (deficit)</span><span id="aDeficit" class="mono font-bold">--</span></div>
            <div class="flex justify-between mt-2" title="After SE 10th sells & LOC pays off — just the UA mortgage + ops"><span class="text-stone-500">Steady-state monthly (after SE 10th sells)</span><span id="aPerm" class="mono font-semibold">--</span></div>
            <div class="flex justify-between" title="Steady-state surplus/(deficit) vs net giving — what the church can run on long-term"><span class="text-stone-500">Steady-state surplus / (deficit)</span><span id="aPermDef" class="mono font-bold">--</span></div>
            <div class="flex justify-between mt-2 pt-2 border-t border-dashed border-stone-200" title="Bank requires building to appraise at this level to lend $3.04M at 75% LTV"><span class="text-stone-500">Appraisal needed for loan</span><span id="aArvNeeded" class="mono font-semibold">--</span></div>
            <div class="flex justify-between" title="Cushion between expected appraisal and minimum required"><span class="text-stone-500">Cushion above bank's threshold</span><span id="aRefiGap" class="mono font-bold">--</span></div>
            <div class="flex justify-between" title="Yes if appraisal is high enough for the bank to lend"><span class="font-semibold">Will the bank fund?</span><span id="aRefiClears" class="font-bold uppercase text-xs px-2 py-0.5 rounded-full">--</span></div>
            <div class="flex justify-between mt-1" title="Gross giving / total facility cost. Higher = healthier."><span class="text-stone-500">Giving ÷ Facility cost</span><span id="aDscr" class="mono font-semibold">--</span></div>
            <div class="flex justify-between mt-1 pt-2 border-t border-dashed border-stone-200" title="Per Board Review: 25-35% healthy, 40%+ facility-heavy/risk"><span class="font-semibold">% of giving to facility</span><span id="aFacilityPct" class="mono font-bold">--</span></div>
          </div>
          <div id="aStory" class="mt-4 pt-3 border-t border-[color:var(--line)] text-[12px] text-stone-700 leading-relaxed bg-[color:var(--mist)] -mx-5 -mb-5 px-5 py-3 rounded-b-2xl"></div>
        </div>

        <!-- Scenario A-Plus — Angel's Counter-Pitch (mirror of A's format) -->
        <div class="scenario-card grid-card rounded-2xl p-5 shadow-sm border-l-4 border-amber-500" id="cardAPlus">
          <div class="flex items-start justify-between mb-2">
            <div>
              <div class="text-xs badge uppercase tracking-[0.18em] text-amber-600">Scenario A-Plus · Angel's Counter</div>
              <h3 class="pp text-xl text-[color:var(--ink)]">$2M to Cinergy + $2M Construction</h3>
            </div>
            <div id="verdictAPlus" class="text-[10px] badge uppercase tracking-wider px-2 py-1 rounded-full">--</div>
          </div>
          <div class="text-[11px] text-stone-500 mb-3">Counter Cinergy to $2M · 20% down ($800K from LOC) · $2M bank construction · Total $4M project · CTP converts to permanent at month 13</div>

          <div class="space-y-2 text-sm">
            <div class="flex justify-between" title="Down payment + closing costs"><span class="text-stone-500">Cash needed at closing</span><span id="apY0" class="mono font-semibold">--</span></div>
            <div class="flex justify-between" title="Bank IO + LOC IO + utilities + SE 10th transition during 12-mo construction"><span class="text-stone-500">Monthly cost during build</span><span id="apBurden" class="mono font-semibold">--</span></div>
            <div class="flex justify-between border-t border-stone-200 pt-2" title="Surplus/deficit vs Layer 2 income during construction"><span class="font-medium">Surplus during build</span><span id="apDeficit" class="mono font-bold">--</span></div>
            <div class="flex justify-between mt-2" title="The mortgage payment after CTP converts to permanent"><span class="text-stone-500">Mortgage after build is done</span><span id="apPerm" class="mono font-semibold">--</span></div>
            <div class="flex justify-between" title="Coverage after construction completes"><span class="text-stone-500">Surplus / (deficit) after build</span><span id="apPermDef" class="mono font-bold">--</span></div>
            <div class="flex justify-between mt-2 pt-2 border-t border-dashed border-stone-200" title="The building must appraise for at least this much for the bank to convert to permanent"><span class="text-stone-500">Building must appraise for</span><span id="apArvNeeded" class="mono font-semibold">--</span></div>
            <div class="flex justify-between" title="Cushion above bank's appraisal threshold at $9.1M ARV"><span class="text-stone-500">Cushion above what bank requires</span><span id="apRefiGap" class="mono font-bold">--</span></div>
            <div class="flex justify-between" title="Yes = bank will convert to permanent. No = we're short on the appraisal."><span class="font-semibold">Will the bank fund?</span><span id="apRefiClears" class="font-bold uppercase text-xs px-2 py-0.5 rounded-full">--</span></div>
            <div class="flex justify-between mt-1" title="Income divided by mortgage payment. 1.0 = exactly enough. 1.2+ = bank likes it."><span class="text-stone-500">Income vs payment ratio</span><span id="apDscr" class="mono font-semibold">--</span></div>
